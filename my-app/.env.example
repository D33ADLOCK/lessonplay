# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
POSTGRES_URL=postgresql://user:password@localhost:5432/lessonplay

# OpenAI model access. Omit AGENT_MODEL_PROVIDER to use OPENAI_API_KEY.
OPENAI_API_KEY=replace_me
# AGENT_MODEL_PROVIDER=chatgpt-codex-oauth
# CODEX_OAUTH_MODEL=gpt-5.5
# CODEX_OAUTH_BASE_URL=https://chatgpt.com/backend-api

# Cloudflare R2 / S3-compatible game publishing
R2_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
R2_S3_REGION=auto
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=lessonplay
R2_PUBLIC_BASE_URL=https://pub-example.r2.dev
